# Copy to .env and fill in real values. Local Supabase values come from
# `pnpm db:start` output. Never commit .env / .env.local.

# Postgres connection (local Supabase Docker shown)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Voyage AI embeddings (RAG chatbot knowledge base) — get a key at voyageai.com
VOYAGE_API_KEY=pa-xxx
VOYAGE_EMBEDDING_MODEL=voyage-3

# Shared secret for internal machine-to-machine routes (e.g. the chat cleanup
# cron). Not a user credential — generate any long random string.
INTERNAL_TASK_TOKEN=change-me-to-a-long-random-string

# Error tracking (optional — leave unset locally)
# SENTRY_DSN=https://xxx@oXXXX.ingest.de.sentry.io/XXXX

# Order confirmation email via Resend (optional — leave unset locally, no-op without it)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# EMAIL_FROM=Aurevo Fashion <orders@aurevofashion.store>
