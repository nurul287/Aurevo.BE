# Copy to .env and fill in real values. Local Supabase values come from
# `pnpm db:start` output. Never commit .env / .env.local.

# Postgres connection (local Supabase Docker shown)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# Anthropic AI
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Voyage AI embeddings (RAG chatbot knowledge base) — get a key at voyageai.com
VOYAGE_API_KEY=pa-xxx
VOYAGE_EMBEDDING_MODEL=voyage-3
VOYAGE_RERANK_MODEL=rerank-2.5-lite

# Shared secret for internal machine-to-machine routes (e.g. the chat cleanup
# cron). Not a user credential — generate any long random string.
INTERNAL_TASK_TOKEN=change-me-to-a-long-random-string

# Error tracking (optional — leave unset locally)
# SENTRY_DSN=https://xxx@oXXXX.ingest.de.sentry.io/XXXX

# Order confirmation email via Resend (optional — leave unset locally, no-op without it)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
# EMAIL_FROM=Aurevo Fashion <orders@aurevofashion.store>

# Courier (Steadfast) — optional; consignment booking/tracking is a no-op without it.
# Api-Key/Secret-Key from the Steadfast merchant portal. COURIER_WEBHOOK_TOKEN is a
# long random string you choose and also paste into Steadfast's Webhook Integration
# "Auth Token (Bearer)" field — they send it back on every webhook call.
# COURIER_API_KEY=your-steadfast-api-key
# COURIER_SECRET_KEY=your-steadfast-secret-key
# COURIER_WEBHOOK_TOKEN=change-me-to-a-long-random-string
COURIER_BASE_URL=https://portal.packzy.com/api/v1
