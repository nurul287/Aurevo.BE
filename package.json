{
  "name": "aurevofashion.backend.api",
  "version": "1.0.0",
  "description": "Aurevo Fashion E-commerce Backend API",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm exec eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "db:start": "pnpm dlx supabase@2.98.2 start",
    "db:stop": "pnpm dlx supabase@2.98.2 stop",
    "db:status": "pnpm dlx supabase@2.98.2 status",
    "db:reset": "pnpm dlx supabase@2.98.2 db reset",
    "db:push": "pnpm dlx supabase@2.98.2 db push",
    "db:migrate:new": "pnpm dlx supabase@2.98.2 migration new",
    "db:migrate:local": "pnpm dlx supabase@2.98.2 migration up --local",
    "db:migration:list": "pnpm dlx supabase@2.98.2 migration list",
    "db:diff": "pnpm dlx supabase@2.98.2 db diff",
    "db:lint": "pnpm dlx supabase@2.98.2 db lint",
    "db:link": "pnpm dlx supabase@2.98.2 link",
    "db:validate": "node scripts/db-validate.mjs",
    "db:types": "pnpm dlx supabase@2.98.2 gen types typescript --linked > src/db/database.types.ts",
    "db:types:local": "pnpm dlx supabase@2.98.2 gen types typescript --local > src/db/database.types.ts",
    "db:dump-prod": "node scripts/db-sync.mjs dump-prod",
    "db:restore-local": "node scripts/db-sync.mjs restore-local",
    "db:sync-from-prod": "node scripts/db-sync.mjs sync-from-prod",
    "db:functions:deploy": "pnpm dlx supabase@2.98.2 functions deploy meta-conversions",
    "db:functions:serve": "pnpm dlx supabase@2.98.2 functions serve meta-conversions --no-verify-jwt",
    "db:introspect": "drizzle-kit introspect",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "ecommerce",
    "api",
    "node",
    "express",
    "drizzle",
    "supabase"
  ],
  "author": "Aurevo",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@sentry/node": "^10.64.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.9",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.0.3",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
